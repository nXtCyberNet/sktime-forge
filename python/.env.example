VALKEY_URL=redis://valkey:6379

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_URI=s3://sktime-agentic-models

S3_BUCKET=sktime-agentic-models
S3_REGION=us-east-1

MIN_HISTORY_LENGTH=10
PREDICTION_TIMEOUT_SECONDS=30
INCREMENTAL_UPDATE_WAIT_SECONDS=10
PREDICTION_INTERVAL_COVERAGE=0.9

CACHE_TTL_HIGH_FREQUENCY_SECONDS=900
CACHE_TTL_DAILY_SECONDS=21600
CACHE_TTL_LOW_FREQUENCY_SECONDS=86400

DRIFT_CHECK_EVERY_N_PREDICTIONS=50
DRIFT_CHECK_EVERY_T_MINUTES=10
NO_DRIFT_THRESHOLD=0.2
MINOR_DRIFT_THRESHOLD=0.3
MAJOR_DRIFT_THRESHOLD=0.5

RETRAIN_LOCK_TTL_SECONDS=1800
MAX_TRAINING_TIME_SECONDS=3600

LLM_PROVIDER=openai_compatible
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=256
LLM_TIMEOUT_SECONDS=30
LLM_RATIONALE_TIMEOUT_SECONDS=6
ENABLE_LLM_RATIONALE=true
LLM_AUTH_HEADER=Authorization
LLM_AUTH_SCHEME=Bearer

ADMIN_API_TOKEN=
ENABLE_FORECAST_WORKER=true
ENABLE_RETRAIN_WORKER=false
LOCAL_DATASET_DIR=./tests/fixtures/sample_datasets


